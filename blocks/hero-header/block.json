{
  "apiVersion": 2,
  "name": "csv/hero-header",
  "title": "Hero Header",
  "category": "design",
  "icon": "cover-image",
  "description": "Dynamic hero header block with title, description, and background image.",
  "editorScript": "file:../../dist/blocks/hero-header.js",
  "editorStyle": "file:./editor.css",
  "render": "file:./render.php",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "YOUR JOURNEY"
    },
    "title": {
      "type": "string",
      "default": "Hero Title"
    },
    "titleSize": {
      "type": "string",
      "default": "default"
    },
    "heroTextColor": {
      "type": "string",
      "default": "default"
    },
    "description": {
      "type": "string",
      "default": "Hero description text"
    },
    "button1Text": {
      "type": "string",
      "default": "Continue to Intentions"
    },
    "button1Url": {
      "type": "string",
      "default": "#"
    },
    "button2Text": {
      "type": "string",
      "default": "View the Full Journey"
    },
    "button2Url": {
      "type": "string",
      "default": "#"
    },
    "backgroundImageId": {
      "type": "number",
      "default": null
    },
    "overlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.4)"
    }
  }
}
