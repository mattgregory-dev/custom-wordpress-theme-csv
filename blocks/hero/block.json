{
  "apiVersion": 2,
  "name": "cwp/hero",
  "title": "Hero",
  "category": "design",
  "icon": "cover-image",
  "description": "Minimal hero block with title and description.",
  "editorScript": "file:../../dist/blocks/hero.js",
  "editorStyle": "file:./editor.css",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "YOUR JOURNEY"
    },
    "title": {
      "type": "string",
      "default": "Hero Title"
    },
    "titleSize": {
      "type": "string",
      "default": "default"
    },
    "heroTextColor": {
      "type": "string",
      "default": "default"
    },
    "description": {
      "type": "string",
      "default": "Hero description text"
    },
    "button1Text": {
      "type": "string",
      "default": "Continue to Intentions"
    },
    "button1Url": {
      "type": "string",
      "default": "#"
    },
    "button2Text": {
      "type": "string",
      "default": "View the Full Journey"
    },
    "button2Url": {
      "type": "string",
      "default": "#"
    },
    "backgroundImageId": {
      "type": "number",
      "default": null
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "overlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.4)"
    }
  }
}
